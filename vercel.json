{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/analyze.js", "use": "@vercel/node" },
    { "src": "api/transcribe.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/transcribe", "dest": "/api/transcribe.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 60
    }
  }
}
